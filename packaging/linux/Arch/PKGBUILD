# Edit on github: https://github.com/papi-ux/polaris/blob/master/packaging/linux/Arch/PKGBUILD
# Reference: https://wiki.archlinux.org/title/PKGBUILD

## options
: "${_run_unit_tests:=false}" # if set to true; unit tests will be executed post build; useful in CI
: "${_support_headless_testing:=false}"
: "${_use_cuda:=detect}" # nvenc

: "${_commit:=@GITHUB_COMMIT@}"

pkgname='polaris'
pkgver=@PROJECT_VERSION@@POLARIS_SUB_VERSION@
pkgrel=1
pkgdesc="@PROJECT_DESCRIPTION@"
arch=('x86_64' 'aarch64')
url=@PROJECT_HOMEPAGE_URL@
license=('GPL-3.0-only')
install=polaris.install

depends=(
  'avahi'
  'boost-libs'
  'curl'
  'libayatana-appindicator'
  'libcap'
  'libdrm'
  'libevdev'
  'libmfx'
  'libnotify'
  'libpulse'
  'libva'
  'libx11'
  'libxcb'
  'libxfixes'
  'libxi'
  'libxrandr'
  'libxtst'
  'mesa'
  'miniupnpc'
  'numactl'
  'openssl'
  'opus'
  'pipewire'
  'udev'
  'wayland'
  'which'
)

makedepends=(
  'appstream'
  'appstream-glib'
  'cmake'
  'desktop-file-utils'
  'gcc'
  'git'
  'make'
  'ninja'
  'nlohmann-json'
  'nodejs'
  'npm'
)

optdepends=(
  'labwc: isolated stream compositor runtime'
  'libva-mesa-driver: AMD GPU encoding support'
)

provides=()
conflicts=()

source=("$pkgname::git+@GITHUB_CLONE_URL@#commit=${_commit}")
sha256sums=('SKIP')

# Options Handling
if [[ "${_use_cuda::1}" == "d" ]] && pacman -Qi cuda &> /dev/null; then
  _use_cuda=true
fi

if [[ "${_use_cuda::1}" == "t" ]]; then
  optdepends+=(
    'cuda: Nvidia GPU encoding support'
  )
fi

if [[ "${_support_headless_testing::1}" == "t" ]]; then
  optdepends+=(
    'xorg-server-xvfb: Virtual X server for headless testing'
  )
fi

# Ensure makedepends, checkdepends, optdepends are sorted
if [ -n "${makedepends+x}" ]; then
  mapfile -t tmp_array < <(printf '%s\n' "${makedepends[@]}" | sort)
  makedepends=("${tmp_array[@]}")
  unset tmp_array
fi

if [ -n "${optdepends+x}" ]; then
  mapfile -t tmp_array < <(printf '%s\n' "${optdepends[@]}" | sort)
  optdepends=("${tmp_array[@]}")
  unset tmp_array
fi

prepare() {
    cd "$pkgname"
    git submodule update --recursive --init
}

build() {
    export BRANCH="@GITHUB_BRANCH@"
    export BUILD_VERSION="@BUILD_VERSION@"
    export COMMIT="${_commit}"

    export CC="gcc"
    export CXX="g++"

    export CFLAGS="${CFLAGS/-Werror=format-security/}"
    export CXXFLAGS="${CXXFLAGS/-Werror=format-security/}"

    # GCC 15 plus Polaris' current Release workaround can conflict with Arch's
    # injected fortify defines during makepkg validation rebuilds.
    if [[ "$(g++ -dumpfullversion | cut -d. -f1)" == "15" ]]; then
      local _filtered_cppflags=()
      local _filtered_cflags=()
      local _filtered_cxxflags=()
      local _flag

      read -r -a _cppflags_array <<< "${CPPFLAGS}"
      for _flag in "${_cppflags_array[@]}"; do
        case "${_flag}" in
          -D_FORTIFY_SOURCE=*|-Wp,-D_FORTIFY_SOURCE=*)
            ;;
          *)
            _filtered_cppflags+=("${_flag}")
            ;;
        esac
      done

      read -r -a _cflags_array <<< "${CFLAGS}"
      for _flag in "${_cflags_array[@]}"; do
        case "${_flag}" in
          -D_FORTIFY_SOURCE=*|-Wp,-D_FORTIFY_SOURCE=*)
            ;;
          *)
            _filtered_cflags+=("${_flag}")
            ;;
        esac
      done

      read -r -a _cxxflags_array <<< "${CXXFLAGS}"
      for _flag in "${_cxxflags_array[@]}"; do
        case "${_flag}" in
          -D_FORTIFY_SOURCE=*|-Wp,-D_FORTIFY_SOURCE=*)
            ;;
          *)
            _filtered_cxxflags+=("${_flag}")
            ;;
        esac
      done

      export CPPFLAGS="${_filtered_cppflags[*]}"
      export CFLAGS="${_filtered_cflags[*]}"
      export CXXFLAGS="${_filtered_cxxflags[*]}"
    fi

    export MAKEFLAGS="${MAKEFLAGS:--j$(nproc)}"

    local _cmake_options=(
      -S "$pkgname"
      -B build
      -G Ninja
      -Wno-dev
      -D BUILD_DOCS=OFF
      -D BUILD_WERROR=ON
      -D BOOST_USE_STATIC=OFF
      -D CMAKE_INSTALL_PREFIX=/usr
      -D POLARIS_EXECUTABLE_PATH=/usr/bin/polaris
      -D POLARIS_ASSETS_DIR="share/polaris"
      -D POLARIS_PUBLISHER_NAME='Polaris Project'
      -D POLARIS_PUBLISHER_WEBSITE='https://github.com/papi-ux/polaris'
      -D POLARIS_PUBLISHER_ISSUE_URL='https://github.com/papi-ux/polaris/issues'
    )

    if [[ "${_use_cuda::1}" != "t" ]]; then
      _cmake_options+=(-DPOLARIS_ENABLE_CUDA=OFF -DCUDA_FAIL_ON_MISSING=OFF)
    else
      # If cuda has just been installed, its variables will not be available in the environment
      # therefore, set them manually to the expected values on Arch Linux
      if [ -z "${CUDA_PATH:-}" ] && pacman -Qi cuda &> /dev/null; then
        export CUDA_PATH=/opt/cuda
      fi

      if [ -n "${CUDA_PATH:-}" ] && [ -x "${CUDA_PATH}/bin/nvcc" ]; then
        export PATH="${CUDA_PATH}/bin:${PATH}"
        export CUDACXX="${CUDA_PATH}/bin/nvcc"
        export NVCC_CCBIN="${NVCC_CCBIN:-/usr/bin/g++}"
        _cmake_options+=(-DCMAKE_CUDA_COMPILER:FILEPATH="${CUDA_PATH}/bin/nvcc")
      fi
    fi

    if [[ "${_run_unit_tests::1}" != "t" ]]; then
      _cmake_options+=(-DBUILD_TESTS=OFF)
    fi

    cmake "${_cmake_options[@]}"

    # appstreamcli treats the legacy hyphenated app ID as a fatal warning.
    appstream-util validate "build/dev.polaris-stream.app.Polaris.metainfo.xml"
    desktop-file-validate "build/dev.polaris-stream.app.Polaris.desktop"
    desktop-file-validate "build/dev.polaris-stream.app.Polaris.terminal.desktop"

    cmake --build build --parallel "$(nproc)"
}

check() {
    cd "${srcdir}/build"
    ./polaris --version

    if [[ "${_run_unit_tests::1}" == "t" ]]; then
      export CC="gcc"
      export CXX="g++"

      cd "${srcdir}/build/tests"
      ./test_polaris --gtest_color=yes
    fi
}

package() {
    DESTDIR="$pkgdir" cmake --install build
}
